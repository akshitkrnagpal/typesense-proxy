# Typesense Connection
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_PROTOCOL=http
TYPESENSE_API_KEY=test-api-key

# Proxy Server
PROXY_PORT=3000
PROXY_API_KEY=your-secret-ingest-key

# Caching
CACHE_TTL=60
CACHE_MAX_SIZE=1000

# Ingestion Queue
QUEUE_CONCURRENCY=5
QUEUE_MAX_SIZE=10000

# Rate Limiting (requests per minute)
RATE_LIMIT_SEARCH=100
RATE_LIMIT_INGEST=30

# Multilingual Collections (JSON)
# COLLECTIONS_CONFIG={"products":{"locales":{"en":"products_en","fr":"products_fr"}}}
