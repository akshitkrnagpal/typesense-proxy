{
  "name": "tsproxy",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build --filter='!docs'",
    "test": "turbo test",
    "typecheck": "turbo run typecheck",
    "lint": "turbo lint",
    "seed": "tsx scripts/seed.ts"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "turbo": "^2.5.0",
    "typescript": "^5.5.3"
  },
  "packageManager": "pnpm@10.12.1",
  "pnpm": {
    "overrides": {
      "react": "19.2.4",
      "react-dom": "19.2.4",
      "@types/react": "^19",
      "@types/react-dom": "^19"
    }
  }
}
