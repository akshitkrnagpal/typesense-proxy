{
  "name": "@tsproxy/api",
  "version": "0.2.0",
  "description": "HonoJS proxy server for Typesense with caching, rate limiting, and ingestion queue",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./nextjs": {
      "types": "./dist/nextjs.d.ts",
      "import": "./dist/nextjs.js",
      "default": "./dist/nextjs.js"
    }
  },
  "bin": {
    "tsproxy-server": "./dist/cli.js"
  },
  "files": ["dist", "README.md"],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/akshitkrnagpal/tsproxy.git",
    "directory": "packages/api"
  },
  "license": "MIT",
  "keywords": ["typesense", "search", "proxy", "hono", "cache", "rate-limit"],
  "scripts": {
    "dev": "tsx watch src/cli.ts dev",
    "build": "tsup src/index.ts src/server.ts src/cli.ts src/nextjs.ts --format esm --dts --tsconfig tsconfig.build.json",
    "start": "node dist/cli.js start",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@hono/zod-openapi": "^0.18.0",
    "bullmq": "^5.73.0",
    "hono": "^4.7.0",
    "hono-rate-limiter": "^0.5.0",
    "typesense": "^3.0.0-2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "vitest": "^3.2.0"
  }
}
