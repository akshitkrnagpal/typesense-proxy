{
  "name": "@tsproxy/cli",
  "version": "0.0.1",
  "description": "CLI for tsproxy — Typesense search proxy framework",
  "type": "module",
  "bin": {
    "tsproxy": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/akshitkrnagpal/tsproxy.git",
    "directory": "packages/cli"
  },
  "license": "MIT",
  "keywords": [
    "typesense",
    "search",
    "proxy",
    "cli"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --target node22",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "typecheck": "echo 'skip'"
  },
  "dependencies": {
    "@clack/prompts": "^0.10.0",
    "commander": "^13.1.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
