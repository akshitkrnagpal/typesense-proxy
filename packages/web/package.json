{
  "name": "@tsproxy/react",
  "version": "0.0.1",
  "description": "Headless React components for tsproxy with BaseUI-style overrides",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/akshitkrnagpal/tsproxy.git",
    "directory": "packages/web"
  },
  "license": "MIT",
  "keywords": ["typesense", "react", "instantsearch", "headless", "search"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --external react --external react-dom --external react-instantsearch --external @tsproxy/js --tsconfig tsconfig.build.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tsproxy/js": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "react-instantsearch": "^7.0.0"
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "tsup": "^8.4.0",
    "typescript": "^5.5.3"
  }
}
